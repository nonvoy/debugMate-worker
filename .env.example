# Application
DEBUG=false
ENVIRONMENT=local
LOG_LEVEL=INFO

# PostgreSQL (required) — incidents and event associations are written here
DB_URL=postgresql://user:password@localhost:5432/mydatabase

# OpenSearch — normalized events are indexed and queried here
OPENSEARCH__URL=http://localhost:9200
OPENSEARCH__USERNAME=admin
OPENSEARCH__PASSWORD=admin
OPENSEARCH__USE_SSL=false
OPENSEARCH__VERIFY_CERTS=false
OPENSEARCH__SSL_ASSERT_HOSTNAME=false
OPENSEARCH__SSL_SHOW_WARN=false
OPENSEARCH__HTTP_COMPRESS=true
OPENSEARCH__TIMEOUT=30
OPENSEARCH__MAX_RETRIES=3
OPENSEARCH__RETRY_ON_TIMEOUT=true
OPENSEARCH__INDEX_CONFIG__NUMBER_OF_SHARDS=1
OPENSEARCH__INDEX_CONFIG__NUMBER_OF_REPLICAS=0

# Celery — the worker consumes the process_events task from this broker
CELERY__APP_NAME=debugmate-worker
CELERY__TASK_NAME=process_events
CELERY__QUEUE_NAME=debugmate-queue

# Local broker (used when ENVIRONMENT=local)
CELERY__BROKER_URL=redis://localhost:6379/0

# Incident detection tuning
INCIDENT__TIME_INTERVAL=300
INCIDENT__FINGERPRINT_THRESHOLD=5
INCIDENT__SERVICE_ENV_THRESHOLD=10

# Non-local (SQS) broker settings — used when ENVIRONMENT is not "local".
# Uncomment and fill in when running against SQS.
# AWS__ACCESS_KEY_ID=
# AWS__SECRET_ACCESS_KEY=
# AWS__REGION=eu-central-1
# CELERY__QUEUE_URL=https://sqs.eu-central-1.amazonaws.com/000000000000/debugmate-queue
# CELERY__ENDPOINT_URL=
# CELERY__IS_SECURE=true
# CELERY__VISIBILITY_TIMEOUT=3600
# CELERY__POLLING_INTERVAL=5
